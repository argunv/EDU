# Production environment template.
#   cp .env.production.example .env
#   ./scripts/gen-secrets.sh   # заполняет JWT / DB / RabbitMQ пароли
#   отредактируйте DOMAIN, FRONTEND_URL, CORS_ORIGINS, SMTP_*
#   ./scripts/check-env.sh
#   ./scripts/deploy.sh
#
# Не коммитьте заполненный .env.

# --- Публичный доступ ---
# Домен без схемы (для CORS/подсказок). FRONTEND_URL — полный https URL.
DOMAIN=edu.example.com
NGINX_HOST_PORT=80
FRONTEND_URL=https://edu.example.com
CORS_ORIGINS=["https://edu.example.com"]

# --- Режим ---
ENVIRONMENT=production
APP_TIMEZONE=UTC

# --- PostgreSQL ---
POSTGRES_USER=abh_edu
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD_32CHARS_MIN
POSTGRES_DB=abh_edu
# В Docker хост БД всегда postgres (имя сервиса).
DATABASE_URL=postgresql+psycopg2://abh_edu:CHANGE_ME_DB_PASSWORD_32CHARS_MIN@postgres:5432/abh_edu

# --- Redis / RabbitMQ ---
REDIS_URL=redis://redis:6379/0
RABBITMQ_USER=abh_edu_mq
RABBITMQ_PASSWORD=CHANGE_ME_MQ_PASSWORD_32CHARS_MIN
RABBITMQ_URL=amqp://abh_edu_mq:CHANGE_ME_MQ_PASSWORD_32CHARS_MIN@rabbitmq:5672/

# --- JWT (≥ 32 случайных символов) ---
JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARS_LONG

# --- SMTP (реальный сервер обязателен для сброса пароля) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@example.com
NOTIFIER_QUEUE=email_tasks

# --- Rate limits (можно оставить дефолты) ---
RATE_LIMIT_LOGIN=5/60
RATE_LIMIT_REGISTER=3/60
RATE_LIMIT_FORGOT=3/300
RATE_LIMIT_RESET=5/60

# --- Первый админ (scripts/create-admin.sh) ---
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Administrator
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD_8PLUS

# --- Опционально: Grafana (--profile observability) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
