# Скопируйте в .env:
#   cp .env.example .env
#
# Dev:  task dev   → http://localhost
# Prod: task up-prod  (см. README → Production)
#
# Node для npm на хосте: версия из .nvmrc (22.12.0).

# Порт nginx на хосте (внутри контейнера всегда 80).
# Если не 80 — добавьте порт в FRONTEND_URL и CORS_ORIGINS.
NGINX_HOST_PORT=80

# PostgreSQL (значения должны совпадать с DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=abh_edu
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/abh_edu

# Redis / RabbitMQ (в Docker — имена сервисов)
REDIS_URL=redis://redis:6379/0
RABBITMQ_USER=edu_mq
RABBITMQ_PASSWORD=edu_mq_dev_pass
RABBITMQ_URL=amqp://edu_mq:edu_mq_dev_pass@rabbitmq:5672/

# Безопасность
# production: JWT_SECRET ≥ 32 случайных символов; значения ниже API отклонит.
JWT_SECRET=dev-only-change-me
ENVIRONMENT=development

# Grafana (только --profile observability). В prod задайте сильный пароль.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=dev-only-change-me

# Часовой пояс (IANA): UTC, Europe/Moscow, …
APP_TIMEZONE=UTC

# CORS — JSON-массив
CORS_ORIGINS='["http://localhost","http://localhost:5173","http://localhost:3000","http://localhost:8000"]'

# Публичный URL сайта в браузере (письма со сбросом пароля). Не имя Docker-сервиса.
# Dev: http://localhost | Vite: http://localhost:5173 | Prod: https://your.domain
FRONTEND_URL=http://localhost

# Обычно не задавать: дефолт /api + proxy Vite. В Docker-сборке уже VITE_API_URL=/api.
# VITE_API_URL=http://localhost:8000/api

# SMTP (notifier требует непустые значения; без реального SMTP письма не уйдут)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=dev
SMTP_PASSWORD=dev
SMTP_FROM=noreply@example.com
NOTIFIER_QUEUE=email_tasks

# Rate limit (для частой смены demo-ролей можно ослабить login)
# RATE_LIMIT_LOGIN=30/60

# Опционально: task create-admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_NAME=Admin
# ADMIN_PASSWORD=secret
