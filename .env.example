# Скопируйте в .env в корне репозитория:
#   cp .env.example .env
#
# Минимальный запуск всего стека:
#   docker compose up -d --build
# Откройте http://localhost (порт 80) или http://localhost:<NGINX_HOST_PORT>: nginx — статика + /api → бэкенд
#
# Локально без Docker: задайте DATABASE_URL на localhost и см. README.
#
# --- Единственная настройка внешнего порта nginx (docker compose; внутри контейнера всегда 80) ---
# Если не 80 — добавьте порт в FRONTEND_URL и CORS_ORIGINS (http://localhost:<порт>).
NGINX_HOST_PORT=80

# --- PostgreSQL (обязательно для docker-compose; должны совпадать с DATABASE_URL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=abh_edu

# URL для API и Alembic. В Docker хост БД — postgres.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/abh_edu

# --- Redis / RabbitMQ (в Docker имена сервисов) ---
REDIS_URL=redis://redis:6379/0
# Учётка брокера (docker-compose создаёт её через RABBITMQ_DEFAULT_*); должна совпадать с URL ниже.
RABBITMQ_USER=edu_mq
RABBITMQ_PASSWORD=edu_mq_dev_pass
RABBITMQ_URL=amqp://edu_mq:edu_mq_dev_pass@rabbitmq:5672/

# --- Безопасность (в production смените на случайные длинные строки) ---
JWT_SECRET=dev-only-change-me
# production + FRONTEND_URL с localhost в одном .env не смешивать — API не поднимется (validate_production_secrets).
ENVIRONMENT=development

# Часовой пояс приложения (IANA), для now() и значений по умолчанию в ORM: UTC, Europe/Moscow, …
APP_TIMEZONE=UTC

# --- CORS: JSON-массив в кавычках (для docker-compose и shell) ---
CORS_ORIGINS='["http://localhost","http://localhost:5173","http://localhost:3000","http://localhost:8000"]'

# Публичный URL фронтенда в браузере (FRONTEND_URL). Им пользуются API/notifier для ссылок в письмах
# (сброс пароля). Не используйте имена Docker-сервисов (web, api, nginx) — только то, что открывает пользователь.
# Примеры:
#   docker compose + nginx:     http://localhost (при NGINX_HOST_PORT=80)
#   Vite на хосте:              http://localhost:5173
#   production:                 https://your.domain
FRONTEND_URL=http://localhost

# База URL для HTTP-запросов фронта к API (сборка Vite / dev). Не подставляйте сюда FRONTEND_URL и наоборот.
# Фронт в Docker-сборке: префикс /api (см. Dockerfile). Для npm run dev можно не задавать — работает proxy Vite.
# VITE_API_URL=/api

# --- SMTP (опционально; без настроек письма не уходят, остальное работает) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

NOTIFIER_QUEUE=email_tasks

# --- ELK (опционально, docker compose --profile elk) ---
# Отдельные переменные не обязательны: см. README → Observability → ELK stack.
# Для JVM Elasticsearch/Logstash увеличьте лимит памяти Docker (~4 GB+).

# --- Опционально: task create-admin (нужен htpasswd в PATH) ---
# ADMIN_EMAIL=admin@example.com
# ADMIN_NAME=Admin
# ADMIN_PASSWORD=secret
