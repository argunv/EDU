# Скопируйте в .env в корне репозитория:
#   cp .env.example .env
#
# Минимальный запуск всего стека:
#   docker compose up -d --build
# Откройте http://localhost:11223 (nginx: статика + /api → бэкенд)
#
# Локально без Docker: задайте DATABASE_URL на localhost и см. README.

# --- PostgreSQL (обязательно для docker-compose; должны совпадать с DATABASE_URL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=abh_edu

# URL для API и Alembic. В Docker хост БД — postgres.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/abh_edu

# --- Redis / RabbitMQ (в Docker имена сервисов) ---
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Безопасность (в production смените на случайные длинные строки) ---
JWT_SECRET=dev-only-change-me
ENVIRONMENT=development

# Часовой пояс приложения (IANA), для now() и значений по умолчанию в ORM: UTC, Europe/Moscow, …
APP_TIMEZONE=UTC

# --- CORS: JSON-массив в кавычках (для docker-compose и shell) ---
CORS_ORIGINS='["http://localhost:11223","http://localhost:5173","http://localhost:3000","http://localhost:8000"]'

# Ссылки в письмах (сброс пароля). При работе через nginx:
FRONTEND_URL=http://localhost:11223

# Фронт в Docker-сборке: префикс /api (см. Dockerfile). Для npm run dev можно не задавать — работает proxy Vite.
# VITE_API_URL=/api

# --- SMTP (опционально; без настроек письма не уходят, остальное работает) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

NOTIFIER_QUEUE=email_tasks

# --- Опционально: task create-admin (нужен htpasswd в PATH) ---
# ADMIN_EMAIL=admin@example.com
# ADMIN_NAME=Admin
# ADMIN_PASSWORD=secret
